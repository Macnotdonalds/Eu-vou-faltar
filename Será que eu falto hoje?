<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Será que falto hoje?</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
            color: #333;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            background-color: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            padding: 30px;
            width: 100%;
            max-width: 500px;
        }
        h1 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 25px;
            font-size: 24px;
        }
        .form-group {
            margin-bottom: 18px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #4a5568;
        }
        select, input[type="number"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #cbd5e0;
            border-radius: 6px;
            font-size: 16px;
            box-sizing: border-box;
            background-color: #fff;
        }
        .sub-group {
            margin-top: 12px;
            padding-left: 15px;
            border-left: 3px solid #e2e8f0;
            display: none;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #3182ce;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 15px;
            transition: background-color 0.2s;
        }
        button:hover {
            background-color: #2b6cb0;
        }
        #resultado-box {
            margin-top: 25px;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            display: none;
            font-weight: bold;
        }
        .resultado-texto {
            font-size: 20px;
            margin-bottom: 5px;
        }
        .saldo-texto {
            font-size: 14px;
            color: #718096;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>🤔 Será que falto hoje?</h1>
    
    <form id="quizForm">
        <div class="form-group">
            <label for="doente">Você está doente?</label>
            <select id="doente" onchange="verificarDoenca()">
                <option value="0">Não</option>
                <option value="1">Sim</option>
            </select>
            
            <div id="grupo-fudido" class="sub-group">
                <label for="fudido">Mas você está tipo FUDIDAMENTE doente?</label>
                <select id="fudido">
                    <option value="0">Não</option>
                    <option value="1">Sim</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label for="horas">Quantas horas você dormiu hoje?</label>
            <input type="number" id="horas" min="0" max="24" value="8" required>
        </div>

        <div class="form-group">
            <label for="atividade">Tem atividade pra entregar hoje?</label>
            <select id="atividade">
                <option value="0">Não</option>
                <option value="1">Sim</option>
            </select>
        </div>

        <div class="form-group">
            <label for="prova">Tem trabalho ou prova pra hoje?</label>
            <select id="prova">
                <option value="0">Não</option>
                <option value="1">Sim</option>
            </select>
        </div>

        <div class="form-group">
            <label for="aulas">Quantas aulas você tem hoje?</label>
            <input type="number" id="aulas" min="0" value="4" required>
        </div>

        <div class="form-group">
            <label for="freq">Qual sua frequência média nas aulas de hoje?</label>
            <select id="freq">
                <option value="Terrivel">Terrível</option>
                <option value="Ruim">Ruim</option>
                <option value="Mediana" selected>Mediana</option>
                <option value="Boa">Boa</option>
                <option value="MuitoBoa">Muito Boa</option>
                <option value="Perfeita">Perfeita</option>
            </select>
        </div>

        <div class="form-group">
            <label for="atarefado">De 0 a 10, o quão atarefado você está?</label>
            <input type="number" id="atarefado" min="0" max="10" value="0">
        </div>

        <div class="form-group">
            <label for="brasil">Tem jogo do Brasil hoje?</label>
            <select id="brasil">
                <option value="0">Não</option>
                <option value="1">Sim</option>
            </select>
        </div>

        <div class="form-group">
            <label for="faltando">Muita gente vai faltar?</label>
            <select id="faltando">
                <option value="0">Não</option>
                <option value="1">Sim</option>
            </select>
        </div>

        <div class="form-group">
            <label for="res">Nível de resenha?</label>
            <select id="res">
                <option value="Nula">Nula</option>
                <option value="Baixissima">Baixíssima</option>
                <option value="Baixa">Baixa</option>
                <option value="Talvez" selected>Talvez</option>
                <option value="Consideravel">Considerável</option>
                <option value="Alta">Alta</option>
                <option value="ProMax">ProMax</option>
            </select>
        </div>

        <button type="button" onclick="calcularSaldo()">Calcular Destino</button>
    </form>

    <div id="resultado-box">
        <div class="resultado-texto" id="resultado-texto"></div>
        <div class="saldo-texto" id="saldo-texto"></div>
    </div>
</div>

<script>
    function verificarDoenca() {
        const doente = document.getElementById('doente').value;
        const grupoFudido = document.getElementById('grupo-fudido');
        if (doente === "1") {
            grupoFudido.style.display = "block";
        } else {
            grupoFudido.style.display = "none";
            document.getElementById('fudido').value = "0";
        }
    }

    function calcularSaldo() {
        let saldo = 0;

        const doente = parseInt(document.getElementById('doente').value);
        if (doente === 1) {
            const fudido = parseInt(document.getElementById('fudido').value);
            if (fudido === 1) {
                mostrarResultado("Fica em casa, é melhor pra você.", 0, "#e53e3e", "#fff");
                return;
            } else {
                saldo += 30;
            }
        }

        const horas = parseInt(document.getElementById('horas').value);
        if (horas >= 6) saldo += 0;
        else if (horas === 5) saldo += 5;
        else if (horas === 4) saldo += 10;
        else if (horas === 3) saldo += 15;
        else if (horas === 2) saldo += 20;
        else if (horas === 1) saldo += 25;
        else saldo += 30;

        const atividade = parseInt(document.getElementById('atividade').value);
        if (atividade === 1) saldo -= 15;

        const prova = parseInt(document.getElementById('prova').value);
        if (prova === 1) saldo -= 35;

        const aulas = parseInt(document.getElementById('aulas').value);
        if (aulas === 0) saldo += 40;
        else if (aulas === 1) saldo += 20;
        else if (aulas === 2) saldo += 10;

        const freq = document.getElementById('freq').value;
        if (freq === "Terrivel") saldo -= 30;
        else if (freq === "Ruim") saldo -= 20;
        else if (freq === "Mediana") saldo -= 10;
        else if (freq === "MuitoBoa") saldo += 5;

        const atarefado = parseInt(document.getElementById('atarefado').value) || 0;
        saldo += atarefado * 3;

        const brasil = parseInt(document.getElementById('brasil').value);
        if (brasil === 1) saldo += 10;

        const faltando = parseInt(document.getElementById('faltando').value);
        if (faltando === 1) saldo += 5;

        const res = document.getElementById('res').value;
        if (res === "Nula") saldo += 15;
        else if (res === "Baixissima") saldo += 10;
        else if (res === "Baixa") saldo += 5;
        else if (res === "Consideravel") saldo -= 10;
        else if (res === "Alta") saldo -= 20;
        else if (res === "ProMax") saldo -= 50;

        let msg = "";
        let bgColor = "";
        let textColor = "#fff";

        if (saldo <= -60) {
            msg = "Brother, você PRECISA ir para a aula.";
            bgColor = "#e53e3e"; // Vermelho escuro
        } else if (saldo <= -20) {
            msg = "Melhor não faltar hoje, vai por mim.";
            bgColor = "#dd6b20"; // Laranja
        } else if (saldo <= 19) {
            msg = "Não tem motivos o suficiente pra faltar.";
            bgColor = "#ecc94b"; // Amarelo
            textColor = "#333";
        } else if (saldo <= 39) {
            msg = "Eh, tanto faz.";
            bgColor = "#a0aec0"; // Cinza
        } else if (saldo <= 59) {
            msg = "Hoje dá pra faltar.";
            bgColor = "#48bb78"; // Verde claro
        } else if (saldo <= 89) {
            msg = "Namoral, eu faltaria se eu fosse você.";
            bgColor = "#38a169"; // Verde
        } else {
            msg = "ZERO motivos pra você ir pra aula hoje.";
            bgColor = "#2f855a"; // Verde escuro
        }

        mostrarResultado(msg, saldo, bgColor, textColor);
    }

    function mostrarResultado(msg, saldo, bgColor, textColor) {
        const box = document.getElementById('resultado-box');
        const txt = document.getElementById('resultado-texto');
        const sld = document.getElementById('saldo-texto');

        txt.innerText = msg;
        sld.innerText = "Saldo Final: " + saldo;
        
        box.style.backgroundColor = bgColor;
        box.style.color = textColor;
        box.style.display = "block";
        
        box.scrollIntoView({ behavior: 'smooth' });
    }
</script>

</body>
</html>
